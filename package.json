{
	"name": "@fabianmewes-jm/fabee-pi-agent",
	"version": "0.1.8",
	"description": "Bee Dance speaking Unix socket agent runtime derived in part from pi-mom",
	"type": "module",
	"bin": {
		"bee-pi-agent": "dist/main.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"homepage": "https://github.com/fabianmewes-jm/Fabee-pi-agent",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/fabianmewes-jm/Fabee-pi-agent.git"
	},
	"bugs": {
		"url": "https://github.com/fabianmewes-jm/Fabee-pi-agent/issues"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"keywords": [
		"ai",
		"agent",
		"bee-dance",
		"unix-socket",
		"worker"
	],
	"files": [
		"dist",
		"CHANGELOG.md",
		"LICENSE",
		"README.md",
		"UPSTREAM.md",
		"charts"
	],
	"scripts": {
		"clean": "shx rm -rf coverage dist",
		"build": "tsgo -p tsconfig.build.json && shx chmod +x dist/main.js",
		"dev": "tsgo -p tsconfig.build.json --watch --preserveWatchOutput",
		"lint": "biome check --error-on-warnings .",
		"lint:fix": "biome check --write --error-on-warnings .",
		"format": "biome format --write .",
		"typecheck": "tsgo --noEmit -p tsconfig.json",
		"test": "vitest run --coverage",
		"test:watch": "vitest",
		"check": "biome check --write --error-on-warnings . && tsgo --noEmit -p tsconfig.json && vitest run --coverage && npm run build",
		"prepare": "husky",
		"prepublishOnly": "npm run clean && npm run check"
	},
	"dependencies": {
		"@jobmatchme/bee-dance-core": "0.1.5",
		"@jobmatchme/bee-dance-schema": "0.2.3",
		"@mariozechner/pi-agent-core": "^0.61.1",
		"@mariozechner/pi-ai": "^0.61.1",
		"@mariozechner/pi-coding-agent": "^0.61.1",
		"@sinclair/typebox": "^0.34.0",
		"chalk": "^5.6.2",
		"diff": "^8.0.2"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.5",
		"@types/diff": "^7.0.2",
		"@types/node": "^24.3.0",
		"@typescript/native-preview": "7.0.0-dev.20260120.1",
		"@vitest/coverage-v8": "^3.2.4",
		"husky": "^9.1.7",
		"shx": "^0.4.0",
		"typescript": "^5.7.3",
		"vitest": "^3.2.4"
	},
	"optionalDependencies": {
		"@typescript/native-preview-linux-arm64": "7.0.0-dev.20260120.1"
	},
	"author": "jobmatchme, derived in part from Mario Zechner's pi-mom",
	"license": "MIT",
	"engines": {
		"node": ">=20.0.0"
	}
}
